{
  "name": "andiko",
  "version": "0.48.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "nodeLinker": "hoisted",
    "patchedDependencies": {
      "next-themes@0.4.6": "patches/next-themes@0.4.6.patch"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:vercel": "pnpm migrate:deploy && pnpm build",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "check": "pnpm -w run \"/^(typecheck|lint|test)$/\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "cucumber-js",
    "test:integration:watch": "cucumber-js --profile=watch",
    "test:integration:ci": "cucumber-js --profile=ci",
    "migrate": "tsx --env-file=.env.local src/db/migrate.ts",
    "migrate:deploy": "tsx src/db/migrate.ts up",
    "migrate:prod": "tsx --env-file=.env.production.local src/db/migrate.ts up",
    "migrate:baseline-prod": "ALLOW_PROD_BASELINE=yes tsx --env-file=.env.production.local src/db/migrate.ts baseline",
    "db:clear-data": "tsx --env-file=.env.local src/db/dev/clear-data.ts",
    "db:seed-dev": "tsx -r ./scripts/cli-server-preload.cjs --env-file=.env.local src/db/dev/seed-dev.ts",
    "db:seed-prod": "ALLOW_PROD_SEED=yes tsx --env-file=.env.production.local src/db/dev/seed-dev.ts",
    "db:reset-prod": "ALLOW_PROD_RESET=yes tsx --env-file=.env.production.local src/db/dev/reset-prod.ts",
    "db:check-perms": "tsx --env-file=.env.local src/db/dev/check-permissions.ts",
    "db:clear-login-throttle": "tsx -r ./scripts/cli-server-preload.cjs --env-file=.env.local src/db/dev/clear-login-throttle.ts",
    "release": "GITHUB_TOKEN=$(gh auth token) release-it",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "pos:dev": "pnpm --filter @andiko/pos dev",
    "pos:setup": "pnpm install && node scripts/pos-install-electron.mjs && pnpm pos:rebuild-native",
    "pos:rebuild-native": "pnpm --filter @andiko/pos rebuild-native"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@googleapis/drive": "^20.2.0",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@ramiidv/arca-sdk": "^1.3.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cap-widget": "^0.1.56",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.6.1",
    "decimal.js": "^10.6.0",
    "jsbarcode": "^3.12.3",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.1",
    "posthog-js": "^1.396.5",
    "posthog-node": "^5.39.4",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.7",
    "recharts": "^3.8.1",
    "sequelize": "^6.37.8",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "umzug": "^3.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@cucumber/cucumber": "^13.0.0",
    "@cucumber/html-formatter": "^24.0.0",
    "@playwright/test": "^1.61.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^24",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-storybook": "^10.3.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.1",
    "release-it": "^19.2.4",
    "sequelize-cli": "^6.6.5",
    "storybook": "^10.3.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
