# Andiko VPS production environment
# Copy to infra/.env.production and fill in values. Never commit infra/.env.production.
#
# Full runbook: docs/deployment/production.md

# --- Docker image ---
GHCR_IMAGE=ghcr.io/cristianemoyano/andiko
STACK_NAME=andiko
DOMAIN=andiko.cloud

# --- PostgreSQL (swarm service: postgres) ---
POSTGRES_USER=andiko
POSTGRES_PASSWORD=change-me-generate-with-openssl
POSTGRES_DB=andiko
POSTGRES_DATA_DIR=/var/lib/andiko/postgres

# App DATABASE_URL — optional; built from POSTGRES_* by prod-init / prod-migrate if omitted
# DATABASE_URL=postgresql://andiko:change-me@postgres:5432/andiko

# --- App secrets ---
# Generate: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl
AUTH_URL=https://andiko.cloud
AFIP_MODE=produccion

# Billing dunning cron (Authorization: Bearer header)
CRON_SECRET=change-me-generate-with-openssl

# --- PostHog (analytics, error tracking, server logs) ---
# Required at Docker build time (NEXT_PUBLIC_* baked into client bundle).
# Also set at runtime for server-side log export and posthog-node.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional: HTTP migrate fallback (CLI migrations are primary on VPS)
# MIGRATION_SECRET=

# --- TLS (Certbot) ---
CERTBOT_EMAIL=admin@andiko.cloud
CERTBOT_CERTS_DIR=/var/lib/andiko/certs
CERTBOT_WWW_DIR=/var/lib/andiko/certbot-www

# --- Portainer (Docker Swarm UI) ---
PORTAINER_DOMAIN=portainer.andiko.cloud
PORTAINER_DATA_DIR=/var/lib/andiko/portainer
PORTAINER_HTPASSWD_FILE=/var/lib/andiko/portainer/.htpasswd
NGINX_CONF_DIR=/var/lib/andiko/nginx/conf.d

# --- Mail (docker-mailserver) ---
MAIL_DOMAIN=mail.andiko.cloud
MAIL_DATA_DIR=/var/lib/andiko/mail/data
MAIL_STATE_DIR=/var/lib/andiko/mail/state
MAIL_CONFIG_DIR=/var/lib/andiko/mail/config
# Generated by make prod-init-mail from infra/mail/docker-mailserver.env.example
MAIL_ENV_FILE=/root/andiko/infra/mail/docker-mailserver.env

# --- Backups (Google Drive via rclone) ---
BACKUP_LOCAL_DIR=/var/lib/andiko/backups
BACKUP_RETENTION_DAYS=7
BACKUP_GDRIVE_REMOTE=gdrive
BACKUP_GDRIVE_FOLDER=andiko-prod-backups
# BACKUP_GDRIVE_SERVICE_ACCOUNT_JSON=
BACKUP_ENCRYPT=no
# BACKUP_AGE_PUBLIC_KEY=
