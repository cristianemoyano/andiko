# docker-mailserver environment — copy to docker-mailserver.env via make prod-init-mail
# Docs: https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/
# Runbook: docs/deployment/mail-server.md

# --- Identity ---
OVERRIDE_HOSTNAME=mail.andiko.cloud
POSTMASTER_ADDRESS=postmaster@andiko.cloud
TZ=America/Argentina/Buenos_Aires

# --- TLS (Let's Encrypt cert shared with nginx — expand with expand-ssl-mail.sh) ---
SSL_TYPE=manual
SSL_CERT_PATH=/etc/letsencrypt/live/andiko.cloud/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/andiko.cloud/privkey.pem
TLS_LEVEL=modern

# --- Docker / Postfix networking ---
PERMIT_DOCKER=none
POSTFIX_INET_PROTOCOLS=ipv4

# --- Features (keep RAM low on KVM 4 VPS) ---
ENABLE_CLAMAV=0
ENABLE_SPAMASSASSIN=0
ENABLE_AMAVIS=0
ENABLE_POP3=0
ENABLE_IMAP=1
ENABLE_SMTP=1
SPOOF_PROTECTION=1

# --- Logging ---
LOG_LEVEL=info
SUPERVISOR_LOGLEVEL=warn
