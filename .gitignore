# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.pnpm-store/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

arca/

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example
!infra/.env.production

# Portainer basic auth (generated on VPS — never commit)
**/.htpasswd
**/.htpasswd.*.example

# WooCommerce local bootstrap output
infra/docker/woocommerce/dev-output/credentials.env

# Mail server env (generated on VPS from .example — never commit secrets)
infra/mail/docker-mailserver.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code — local worktrees (nested git repos; never commit)
.claude/worktrees/
.claude/settings.json

# Impeccable — local hook cache, live sessions, per-dev overrides
.impeccable/

# Duplicate skills install (canonical copy lives in .agents/skills/)
/agent/

# Cursor — local IDE settings and agent plans (never commit)
.cursor/*
!.cursor/skills/
!.cursor/skills/**

# Storybook static build output
/storybook-static/

# CSV
*.csv

# Terraform — local provider cache and secrets
infra/terraform/**/.terraform/
infra/terraform/**/terraform.tfvars
infra/terraform/**/tfplan
infra/terraform/**/*.tfstate
infra/terraform/**/*.tfstate.*
