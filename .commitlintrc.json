{
  "extends": [
    "@commitlint/config-conventional"
  ],
  "rules": {
    "scope-enum": [
      2,
      "always",
      [
        "sales",
        "inventory",
        "purchases",
        "contacts",
        "accounting",
        "auth",
        "core",
        "logistics"
      ]
    ],
    "scope-empty": [
      2,
      "never"
    ]
  }
}
