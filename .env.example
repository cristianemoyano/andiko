# Copy this file to .env.local and fill in the values
# Never commit .env.local

# PostgreSQL
POSTGRES_USER=andiko
POSTGRES_PASSWORD=andiko
POSTGRES_DB=andiko_dev
POSTGRES_PORT=5433
DATABASE_URL=postgresql://andiko:andiko@localhost:5433/andiko_dev

# pgAdmin
PGADMIN_EMAIL=admin@andiko.local
PGADMIN_PASSWORD=andiko
PGADMIN_PORT=5050

# Auth (next-auth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-in-production
AUTH_URL=http://localhost:3000

# Landing contact form (Web3Forms — https://web3forms.com)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Migration endpoint protection (production only)
# Generate with: openssl rand -base64 32
# Must be at least 32 chars. Set in Vercel env vars.
MIGRATION_SECRET=

# Production DB ops (local CLI only — never commit this file)
# Pull from Vercel: vercel env pull .env.production.local --environment=production
# Fresh prod DB: pnpm db:reset-prod && pnpm migrate:prod && pnpm db:seed-prod
# Generate passwords: openssl rand -base64 24
SEED_SYSADMIN_PASSWORD=
SEED_DEMO_ADMIN_PASSWORD=
SEED_DEMO_OPERATOR_PASSWORD=
SEED_PREMIUM_ADMIN_PASSWORD=
