# Copy this file to .env.local and fill in the values
# Never commit .env.local

# PostgreSQL
POSTGRES_USER=andiko
POSTGRES_PASSWORD=andiko
POSTGRES_DB=andiko_dev
POSTGRES_PORT=5433
DATABASE_URL=postgresql://andiko:andiko@localhost:5433/andiko_dev

# pgAdmin
PGADMIN_EMAIL=admin@andiko.local
PGADMIN_PASSWORD=andiko
PGADMIN_PORT=5050

# WooCommerce local (docker compose) — see docs/dev/woocommerce-local.md
WOO_PORT=8080
WOO_STORE_URL=http://localhost:8080
# Webhooks desde el contenedor WordPress hacia Andiko en el host:
# AUTH_URL=http://host.docker.internal:3000

# Auth (next-auth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-in-production
AUTH_URL=http://localhost:3000

# Landing contact form (Web3Forms — https://web3forms.com)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# File storage (vendor-agnostic; AWS S3 backend)
# Single platform bucket — tenants are isolated by key prefix (org_id/...).
# Required in production. In dev you can point at MinIO via S3_ENDPOINT.
FILE_STORAGE_PROVIDER=s3
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: override endpoint for S3-compatible stores (MinIO/R2). Leave empty for AWS.
S3_ENDPOINT=
# Max bytes per upload (default 25 MiB)
FILE_MAX_BYTES=26214400
# Dev/staging alternative backend: Google Drive via a service account (bytes proxied through
# the app). Set FILE_STORAGE_PROVIDER=gdrive and provide both values below.
# GDRIVE_SERVICE_ACCOUNT_JSON = base64 of the service-account key JSON:
#   base64 -w0 service-account.json
# Share the target Drive folder with the service account's email, then put its id here.
GDRIVE_SERVICE_ACCOUNT_JSON=
GDRIVE_FOLDER_ID=

# Migration endpoint protection (production only)
# Generate with: openssl rand -base64 32
# Must be at least 32 chars. Set in Vercel env vars.
MIGRATION_SECRET=

# Production DB ops (local CLI only — never commit this file)
# Pull from Vercel: vercel env pull .env.production.local --environment=production
# VPS production: see docs/deployment/production.md and infra/.env.production.example
# Fresh prod DB: pnpm db:reset-prod && pnpm migrate:prod && pnpm db:seed-prod
# Generate passwords: openssl rand -base64 24
SEED_SYSADMIN_PASSWORD=
SEED_DEMO_ADMIN_PASSWORD=
SEED_DEMO_OPERATOR_PASSWORD=
SEED_PREMIUM_ADMIN_PASSWORD=
