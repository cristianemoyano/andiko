# Copy this file to .env.local and fill in the values
# Never commit .env.local

# PostgreSQL
POSTGRES_USER=andiko
POSTGRES_PASSWORD=andiko
POSTGRES_DB=andiko_dev
POSTGRES_PORT=5433
DATABASE_URL=postgresql://andiko:andiko@localhost:5433/andiko_dev

# pgAdmin
PGADMIN_EMAIL=admin@andiko.local
PGADMIN_PASSWORD=andiko
PGADMIN_PORT=5050

# WooCommerce local (docker compose) — see docs/dev/woocommerce-local.md
WOO_PORT=8080
WOO_STORE_URL=http://localhost:8080
# Webhooks desde el contenedor WordPress hacia Andiko en el host:
# AUTH_URL=http://host.docker.internal:3000

# Auth (next-auth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-in-production
AUTH_URL=http://localhost:3000

# PostHog (product analytics, error tracking, logs)
# Project token: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Local dev: PostHog is disabled unless you set this to true
# NEXT_PUBLIC_POSTHOG_DEV=true

# Umami (self-hosted pageview analytics — complements PostHog)
# NEXT_PUBLIC_UMAMI_HOST=http://localhost:3001
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_DEV=true

# Cap (self-hosted invisible CAPTCHA)
# NEXT_PUBLIC_CAP_HOST=http://localhost:3002
# NEXT_PUBLIC_CAP_SITE_KEY=
# CAP_SECRET_KEY=
# CAP_VERIFY_URL=http://localhost:3002/siteverify
# NEXT_PUBLIC_CAP_DEV=true

# Landing contact form (Web3Forms — server-side via /api/v1/public/contact)
WEB3FORMS_ACCESS_KEY=
# Legacy client key (fallback only):
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=


# File storage — configured in Sys-admin → Almacenamiento (platform_settings table).
# Only the per-upload size cap lives here as a deployment safety limit.
FILE_MAX_BYTES=26214400

# Migration endpoint protection (production only)
# Generate with: openssl rand -base64 32
# Must be at least 32 chars. Set in Vercel env vars.
MIGRATION_SECRET=

# Production DB ops (local CLI only — never commit this file)
# Pull from Vercel: vercel env pull .env.production.local --environment=production
# VPS production: see docs/deployment/production.md and infra/.env.production.example
# Fresh prod DB: pnpm db:reset-prod && pnpm migrate:prod && pnpm db:seed-prod
# Generate passwords: openssl rand -base64 24
SEED_SYSADMIN_PASSWORD=
SEED_DEMO_ADMIN_PASSWORD=
SEED_DEMO_OPERATOR_PASSWORD=
SEED_PREMIUM_ADMIN_PASSWORD=
